# Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API（オプション：content agentでprovider=openaiを使う場合）
OPENAI_API_KEY=your_openai_api_key_here

# Notion API
NOTION_API_KEY=your_notion_api_key_here
NOTION_RESEARCH_DB_ID=your_notion_database_id_here

# Web Search（Brave Search API）
BRAVE_SEARCH_API_KEY=your_brave_search_api_key_here

# Google Drive（サービスアカウントJSONのパス）
GOOGLE_SERVICE_ACCOUNT_JSON=path/to/service_account.json
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id_here

# Gmail連携（返信ドラフト自動作成。送信は行わない）
# OAuthクライアントのJSON（初回認証 python tools/gmail_auth_setup.py で使用）
GMAIL_CREDENTIALS_JSON=path/to/gmail_client_secret.json
# 初回認証後に自動生成される認証トークンの保存先
GMAIL_TOKEN_PATH=token.json
# 処理済みメールIDの記録ファイル（重複ドラフト防止）
GMAIL_STATE_PATH=gmail_state.json
# 対象とする送信者（カンマ区切り）。個人情報保護のため、ラベルと合わせて必ずどちらかを設定する
GMAIL_ALLOWED_SENDERS=client-a@example.com,client-b@example.com
# 対象とするGmailラベル（任意）
GMAIL_LABEL=営業
